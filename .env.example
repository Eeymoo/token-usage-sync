PORT=8787
QUESTDB_CONFIG=http::addr=127.0.0.1:9000
# QUESTDB_ENABLED=true
# QUESTDB_ADDR=127.0.0.1:9000
# QUESTDB_USERNAME=
# QUESTDB_PASSWORD=
# QUESTDB_TOKEN=

OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

OPENAI_PROXY_PREFIX=/openai
ANTHROPIC_PROXY_PREFIX=/anthropic
GEMINI_PROXY_PREFIX=/gemini

REQUEST_CAPTURE_LIMIT_BYTES=1048576
RESPONSE_CAPTURE_LIMIT_BYTES=2097152
CONTENT_LIMIT_CHARS=20000

# Optional test variables
# TEST_PROXY_BASE_URL=http://127.0.0.1:19087
# TEST_QUESTDB_EXEC_URL=http://127.0.0.1:9000/exec
# TEST_OPENAI_TOKEN=
# TEST_OPENAI_MODEL=
